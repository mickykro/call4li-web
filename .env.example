# === Call4li Landing — Environment Variables ===

# App domain (used in SEO canonical URLs)
VITE_DOMAIN_URL=https://call4li.com

# OAuth portal URL (for login CTA)
VITE_OAUTH_PORTAL_URL=

# App ID
VITE_APP_ID=

# Analytics (Umami)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# === Functional Integrations (from forley-always-on-ai) ===

# n8n webhook — contact form lead capture
# Receives: { name, company_name, business_description, email, phone, timestamp, source }
VITE_N8N_CONTACT_WEBHOOK_URL=

# n8n webhook — onboarding / activation events
# Receives: { event, client_id, action, timestamp }
VITE_N8N_ONBOARDING_WEBHOOK_URL=

# WhatsApp phone number for direct contact (e.g. 972553163293)
VITE_WHATSAPP_PHONE=972553163293
